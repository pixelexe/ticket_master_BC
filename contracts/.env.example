# Sepolia RPC endpoint (public RPC or provider such as Alchemy/Infura)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com/

# Public MetaMask address used as the seller and contract owner
SELLER_ADDRESS=0xYourSellerWalletAddress

# Address of an already deployed TicketNFT contract on Sepolia
# Leave empty before the first deployment
TICKET_NFT_ADDRESS=

# Private key of the dedicated seller development wallet
# Never commit the real value
PRIVATE_KEY=your_private_key

# JWT created from the Pinata API Keys page
# Never commit the real value
PINATA_JWT=your_pinata_jwt
